@startuml
title C4 Container - Deposit Rates Distribution

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #4A4A4A
  BackgroundColor #F7F7F7
}
skinparam database {
  BorderColor #4A4A4A
  BackgroundColor #FCFCFC
}
skinparam actor {
  BorderColor #4A4A4A
  BackgroundColor #FFFFFF
}

actor "Оператор кол-центра" as BankAgent
actor "Партнёрский оператор" as PartnerAgent

package "АБС" {
  rectangle "Rate Registry Module\n[Container]\nРеестр ставок\nи правил" as RateRegistry
}

package "Deposit MVP" {
  rectangle "ABS Adapter\n[Container]\nВыгрузка ставок\nиз АБС" as AbsAdapter
  rectangle "Rate Publication Service\n[Container]\nВнутренний API\nдля кол-центра" as RatePublicationService
  rectangle "Partner Export Job\n[Container]\nФормирование и\nотправка файлов" as PartnerExportJob
  database "Deposit DB\n[Container]\nПубличный срез ставок\nи журнал публикаций" as DepositDb
}

package "Система кол-центра банка" {
  rectangle "Rate Widget\n[Container]\nЭкран ставок для\nоператора" as RateWidget
  database "Call Center DB\n[Container]\nОпциональный кэш" as CallCenterDb
}

package "Партнёрский контур" {
  rectangle "Partner Mailbox\n[Container]\nПолучение файлов" as PartnerMailbox
  rectangle "Partner Rate Import\n[Container]\nЗагрузка ставок\nв систему партнёра" as PartnerRateImport
}

BankAgent --> RateWidget : Открывает ставки
RateWidget --> RatePublicationService : REST/TLS\nполучить ставки
RateWidget --> CallCenterDb : Кэширует срез
RatePublicationService --> DepositDb : Читает опубликованный\nсрез ставок

AbsAdapter --> RateRegistry : Читает ставки и правила
AbsAdapter --> DepositDb : Обновляет read model

PartnerExportJob --> DepositDb : Читает срез ставок
PartnerExportJob --> PartnerMailbox : Отправляет файл
PartnerMailbox --> PartnerRateImport : Передаёт файл
PartnerAgent --> PartnerRateImport : Использует ставки

@enduml
